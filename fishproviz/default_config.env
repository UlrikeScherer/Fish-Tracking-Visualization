#!/bin/bash

MIN_BATCH_IDX=0 # SPECIFY THE MINIMUM BATCH-INDEX OF THE DAY TO INCLUDE
MAX_BATCH_IDX=12 # SPECIFY THE MAXIMUM BATCH-INDEX OF THE DAY TO INCLUDE (highest batch index)
HOURS_PER_DAY=6 # SPECIFY THE NUMBER OF HOURS TRACKED PER DAY
BATCH_SIZE=10000  # Number of data frames per batch
FRAMES_PER_SECOND=5 # Number of frames per second
PROJECT_ID="survival_of_the_fishest" # The BLOCKID of the experiment, not necessary to specify, just a name for directories

# ---- PATHS -----
path_csv_local="data/PE/PE_feeding_final_block3"
path_recordings="/path/to/remote/recordings"
POSITION_STR_FRONT="PE_feeding_final_block3_front"
POSITION_STR_BACK="PE_feeding_final_block3_back"
OBJECT_ZONE_COORDS_PATH="data/sociability_zones"

# ---- FEEDING -----
SERVER_FEEDING_TIMES_FILE="data/PE/PE_feeding_times.csv"
TRIAL_TIMES_CSV="data/PE/PE_feeding_times.csv"
SERVER_FEEDING_TIMES_SEP=","

FEEDING_PATCH_COORDS_FILE="data/PE_feeding/PE_feeding_patch_coords.csv"
FEEDING_PATCH_COORDS_SEP=","

FEEDING_SHAPE="patch" # or "ellipse"
FEEDING_SHAPE_WIDTH=10
FEEDING_SHAPE_HEIGHT=5
MAGNET_LENGTH_CM=2.5

# ---- CALIBRATION -----
CALIBRATION_DIST_CM=83.0
DEFAULT_CALIBRATION=0.02278

# ---- AREA CONFIG -----
area_folder="area_config"
area_back="areas_back"
area_front="areas_front"

# ---- FILTERING -----
AREA_FILTER=0 # 1 to filter by area, 0 to not filter
DIRT_FILTER=0 # 1 to filter by dirt, 0 to not filter
SPIKE_THRESHOLD=10  # In centimeters. Steps above this are flagged as errors
DIRT_THRESHOLD=1000000  # Consecutive equal frames before a point is classified as dirt
THRESHOLD_AREA_PX=5000  # Pixels outside this threshold are excluded from the tank area

# ---- METRICS -----
TANGLE_N_SKIP=0 # Frames to skip when computing turning angle (0 = highest resolution)
UNAVERAGED=0 # 1=save raw observations, 0=save averaged metrics
AGGREGATE_EVERY_N=1 # Window size for non-overlapping aggregation when UNAVERAGED=1
REMOVE_0_VECS=0 # 1=remove zero vectors from turning angle calculation, 0=keep them
DIST_FROM_WALL_TANGLE_IGNORED=0 # CM distance from wall below which turning angle is ignored

# ---- OUTPUT DIRECTORIES (no changes needed) -----
VIS_DIR="visualisations"
PLOTS_DIR=visualisations/plots
P_FEEDING="feeding"
P_NOVEL_OBJECT="novel_object"
P_TRAJECTORY="trajectory"
P_SOCIABILITY="sociability"
CONFIG_DATA="config_data"
RESULTS="results"
TEX_DIR="tex"
